{
  "name": "GitJournal",
  "version": "2.1.1",
  "description": "Journal de travail Git - Application Electron",
  "main": "src/main.js",
  "type": "module",
  "scripts": {
    "start": "electron .",
    "dev": "NODE_ENV=development electron .",
    "test": "node --test src/server/server.test.js",
    "build": "pnpm test && electron-builder",
    "build:mac": "pnpm test && electron-builder --mac",
    "build:win": "pnpm test && electron-builder --win",
    "build:linux": "pnpm test && electron-builder --linux"
  },
  "dependencies": {
    "ejs": "^3.1.10",
    "express": "^4.19.2",
    "express-ejs-layouts": "^2.5.1",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0"
  },
  "build": {
    "appId": "com.gitjournal.app",
    "productName": "GitJournal",
    "files": [
      "src/main.js",
      "src/preload.js",
      "src/version.js",
      "src/settings.html",
      "src/new-project.html",
      "src/server/**/*",
      "src/assets/**/*"
    ],
    "directories": {
      "output": "dist",
      "buildResources": "src/assets"
    },
    "mac": {
      "icon": "src/assets/icon.icns",
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "src/assets/icon.ico",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "icon": "src/assets/icon.png",
      "target": [
        "AppImage",
        "deb"
      ]
    }
  }
}
