<main id="mainContent">
  <div
    id="divStatsButton"
    class="topButton no-print"
    style="background-color: transparent; border-color: #999; color: #666; right: 70px"
  >
    i
  </div>
  <div
    id="divHelpButton"
    class="topButton no-print"
    style="background-color: transparent; border-color: #999; color: #666"
  >
    ?
  </div>
  <header class="print-only">
    <% if (owner && repo) { %>
    <h1>Journal de travail de <%= me %> dans <%= projectName %></h1>
    <% } else { %>
    <h1>Journal de travail de <%= me %> - <%= projectName %></h1>
    <% } %>
  </header>
  <% if (since) { %>
  <p class="muted print-only">Depuis: <strong><%= since %></strong></p>
  <% } %>

  <%
    const durIdx = columns.findIndex(c => c.format === 'duration');
    const leftSpan = durIdx >= 0 ? durIdx : columns.length;
    const rightSpan = durIdx >= 0 ? columns.length - durIdx : 0;
  %>

  <table>
    <thead>
      <tr>
        <% columns.forEach(col => { %>
        <th><%= col.label %></th>
        <% }) %>
      </tr>
    </thead>

    <tbody>
      <% groups.forEach(g => { %>
      <% g.commits.forEach(c => { %> <%- include('_commitRow', { c }) %> <% }) %>
      <tr style="background: #fafafa; font-weight: bold">
        <% if (rightSpan > 0) { %>
        <td colspan="<%= leftSpan %>" style="text-align: right"><%= g.label %></td>
        <td colspan="<%= rightSpan %>"><%= g.total.h %>h <%= g.total.m %>m</td>
        <% } else { %>
        <td colspan="<%= columns.length %>" style="text-align: right"><%= g.label %></td>
        <% } %>
      </tr>
      <% }) %>
      <tr style="background: #ccc; font-weight: bold">
        <% if (rightSpan > 0) { %>
        <td colspan="<%= leftSpan %>" style="text-align: right">Total du projet</td>
        <td colspan="<%= rightSpan %>"><%= totals.h %>h <%= totals.m %>m</td>
        <% } else { %>
        <td colspan="<%= columns.length %>" style="text-align: right">Total du projet</td>
        <% } %>
      </tr>
    </tbody>
  </table>
  <div style="text-align: center; margin-top: 15px">
    <div id="divAddButton" class="addButton no-print" style="display: inline-block">+</div>
  </div>
  <div class="no-print" style="color: #ccc; font-size: 0.75rem; font-style: italic">GitJournal v<%= appVersion %></div>

  <%- include('_editEntry') %> <%- include('_helpModal') %> <%- include('_statsModal') %>
</main>
<script>
  const EDITABLE_FIELDS = <%- JSON.stringify(columns.filter(c => c.field).map(c => c.field)) %>;

  function getField(name) {
    return document.getElementById('field_' + name);
  }

  const openBtn = document.getElementById("divAddButton");
  const closeBtn = document.getElementById("closeBtn");
  const overlay = document.getElementById("overlay");

  openBtn.onclick = () => {
    document.getElementById("heaInputForm").innerText = "Ajout d'une entrée";
    EDITABLE_FIELDS.forEach(field => {
      const el = getField(field);
      if (!el) return;
      if (field === 'date') {
        const d = new Date();
        const pad = n => String(n).padStart(2, '0');
        el.value = `${d.getFullYear()}-${pad(d.getMonth()+1)}-${pad(d.getDate())}T${pad(d.getHours())}:${pad(d.getMinutes())}`;
      } else {
        el.value = '';
      }
    });
    overlay.classList.add("active");
    document.getElementById("hidSHA").value = "-";
    document.getElementById("exceptionId").value = "-";
    document.getElementById("url").value = "-";
    document.getElementById("excludeBtn").style.display = "none";
  };

  closeBtn.onclick = () => overlay.classList.remove("active");
  overlay.onclick = (e) => {
    if (e.target === overlay) overlay.classList.remove("active");
  };

  document.querySelectorAll("tr").forEach((tr) => {
    tr.addEventListener("click", (e) => {
      if (e.target.tagName === "A" || e.target.closest("a")) return;
      const row = e.currentTarget;
      if (!row.dataset.date) return;

      e.preventDefault();
      document.getElementById("heaInputForm").innerText = "Modification d'une entrée";

      EDITABLE_FIELDS.forEach(field => {
        const el = getField(field);
        if (!el) return;
        if (field === 'date') {
          const d = new Date(row.dataset.date);
          const pad = n => String(n).padStart(2, '0');
          el.value = `${d.getFullYear()}-${pad(d.getMonth()+1)}-${pad(d.getDate())}T${pad(d.getHours())}:${pad(d.getMinutes())}`;
        } else if (row.dataset[field] !== undefined) {
          el.value = row.dataset[field];
        }
      });

      overlay.classList.add("active");
      document.getElementById("hidSHA").value = row.dataset.sha;
      document.getElementById("exceptionId").value = row.dataset.exceptionid;
      document.getElementById("url").value = row.dataset.url;
      document.getElementById("author").value = row.dataset.author;

      const sha = row.dataset.sha;
      const excId = row.dataset.exceptionid;
      if (sha && sha !== "-") {
        document.getElementById("excludeBtn").textContent = "Exclure";
        document.getElementById("excludeBtn").style.display = "block";
      } else if (excId && excId !== "-") {
        document.getElementById("excludeBtn").textContent = "Supprimer";
        document.getElementById("excludeBtn").style.display = "block";
      } else {
        document.getElementById("excludeBtn").style.display = "none";
      }
    });
  });

  const excludeBtn = document.getElementById("excludeBtn");

  excludeBtn.onclick = async () => {
    const sha = document.getElementById("hidSHA").value;
    const excId = document.getElementById("exceptionId").value;
    const isManualEntry = excId && excId !== "-";
    const isCommit = sha && sha !== "-";

    if (isManualEntry) {
      if (!confirm("Voulez-vous vraiment supprimer cette entrée manuelle ?")) return;
      try {
        const response = await fetch("/delete", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ exceptionId: excId })
        });
        if (response.ok) {
          overlay.classList.remove("active");
          window.location.reload();
        } else {
          const error = await response.json();
          alert("Erreur lors de la suppression: " + (error.error || "Erreur inconnue"));
        }
      } catch (error) {
        alert("Erreur lors de la suppression: " + error.message);
      }
    } else if (isCommit) {
      if (!confirm("Voulez-vous vraiment exclure ce commit du journal ?")) return;
      try {
        const response = await fetch("/exclude", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ sha })
        });
        if (response.ok) {
          overlay.classList.remove("active");
          window.location.reload();
        } else {
          const error = await response.json();
          alert("Erreur lors de l'exclusion: " + (error.error || "Erreur inconnue"));
        }
      } catch (error) {
        alert("Erreur lors de l'exclusion: " + error.message);
      }
    } else {
      alert("Cette entrée ne peut être ni exclue ni supprimée");
    }
  };

  const helpBtn = document.getElementById("divHelpButton");
  const helpOverlay = document.getElementById("helpOverlay");
  helpBtn.onclick = () => helpOverlay.classList.add("active");
  helpOverlay.onclick = (e) => {
    if (e.target === helpOverlay) helpOverlay.classList.remove("active");
  };

  const statsBtn = document.getElementById("divStatsButton");
  const statsOverlay = document.getElementById("statsOverlay");
  statsBtn.onclick = () => statsOverlay.classList.add("active");
  statsOverlay.onclick = (e) => {
    if (e.target === statsOverlay) statsOverlay.classList.remove("active");
  };

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") {
      overlay.classList.remove("active");
      helpOverlay.classList.remove("active");
      statsOverlay.classList.remove("active");
    }
  });
</script>
