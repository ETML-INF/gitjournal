<tr
  data-sha="<%= c.sha ?? '-'%>"
  data-url="<%= c.url ?? '-'%>"
  data-exceptionid="<%= c.id ?? '-'%>"
  data-date="<%= c.date ?? ''%>"
  data-author="<%= c.author ?? '?'%>"
  data-status="<%= c.status ?? ''%>"
  data-name="<%= c.name ?? ''%>"
  data-description="<%= c.description ?? ''%>"
  data-duration="<%= c.duration ?? 0%>"
>
  <% c.cells.forEach(cell => { %>
  <td<% if (cell.column.format === 'duration') { %> style="width: 70px"<% } else if (cell.column.field === 'description') { %> style="white-space: pre-wrap"<% } %>>
    <% if (cell.column.format === 'date') { %>
    <%= new Date(cell.value).toLocaleString('fr-CH', { year: 'numeric', month: '2-digit', day: '2-digit', hour: '2-digit', minute: '2-digit' }) %>
    <% } else if (cell.column.format === 'duration') { %>
    <%= Math.floor(Number(cell.value||0)/60) %>h <%= Number(cell.value||0)%60 %>m
    <% } else if (cell.column.format === 'badge') { %>
    <span class="badge"><%= cell.value %></span>
    <% } else { %>
    <%= cell.value %>
    <% } %>
  </td>
  <% }) %>
  <% if (c.sha) { %>
  <td
    style="border: none"
    class="<%= c.patch ? 'patchedcommit' : '' %> no-print"
    title="<%= c.patch ? 'Cette entrée a été éditée localement, elle est différente de ce qui se trouve sur GitHub' : '' %>"
  >
    <a href="<%= c.url %>" target="_blank" rel="noopener noreferrer" style="text-decoration: none"
      ><%- include('_githublogo') %>
    </a>
  </td>
  <% } %>
</tr>
