<main style="text-align: center; padding: 4rem;">
  <h1 style="color: #d32f2f;">⚠️ Erreur</h1>
  <div style="max-width: 600px; margin: 2rem auto; padding: 1.5rem; background: #ffebee; border-radius: 8px; border-left: 4px solid #d32f2f;">
    <p style="font-size: 1.1rem; color: #333; margin: 0;"><%= errorMessage %></p>
  </div>

  <div style="margin-top: 2rem;">
    <p>Rechargez la page après avoir corrigé le problème.</p>
  </div>

  <div style="margin-top: 3rem;">
    <button onclick="location.reload()" style="padding: 12px 24px; font-size: 1rem; background: #2196F3; color: white; border: none; border-radius: 4px; cursor: pointer;">
      🔄 Recharger la page
    </button>
  </div>
</main>
